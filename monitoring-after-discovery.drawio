        <mxCell id="legend" value="Вниз (синяя): действие пользователя → ответ системы в той же фазе.&#xa;Вправо вверх (зелёная): от действия системы к следующему действию пользователя." style="text;html=1;strokeColor=#cccccc;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="1000" height="48" as="geometry" />
        </mxCell>
