        <mxCell id="e_u2s2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="u2" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_s2u3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82b366;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="s2" target="u3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="275" />
              <mxPoint x="720" y="135" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_u3s3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="u3" target="s3">
          <mxGeometry relative="1" as="geometry" />
