# База данных
DATABASE_URL="postgresql://sporthub:sporthub@localhost:5432/sporthub?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth.js
AUTH_SECRET="сгенерировать: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Суперадмин (создаётся при seed, вход через /superadmin/login)
SUPERADMIN_EMAIL="admin@sporthub.ru"
SUPERADMIN_PASSWORD="changeme_in_production"

# Yandex SMTP (отправка email: OTP, сброс пароля)
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-email@yandex.ru"
SMTP_PASSWORD="your-app-password"

# Загрузка файлов (выбрать один из вариантов)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
# или S3-совместимое хранилище
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="sporthub-uploads"

# Мультитенантность
ROOT_DOMAIN="sporthub.ru"
NEXT_PUBLIC_ROOT_DOMAIN="sporthub.ru"

# Приложение
NEXT_PUBLIC_APP_URL="http://localhost:3000"
